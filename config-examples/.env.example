# ═══════════════════════════════════════════════════════════════════════
#  .env.example — copy to .env and fill in your values for live mode
# ═══════════════════════════════════════════════════════════════════════
#  Paper mode requires NO credentials. You can run:
#     TRADING_MODE=paper npm run live:paper
#  without setting anything else.
#
#  Live mode MINIMUM: TRADING_MODE=live + PRIVATE_KEY
#  (and FUNDER_ADDRESS if using a proxy wallet, i.e. SIGNATURE_TYPE=1 or 2)
#
#  NEVER commit a filled-in .env to git.

# ── Mode ──────────────────────────────────────────────────────────────
TRADING_MODE=paper                  # paper | live
KILL_SWITCH=0                       # 1 = halt immediately, don't place orders
KILL_SWITCH_FILE=.KILL              # create this file to trigger kill switch
LOG_LEVEL=info                      # debug | info | warn | error

# ── Wallet (LIVE MODE ONLY) ───────────────────────────────────────────
# Export from reveal.polymarket.com (email login) or your Web3 wallet.
# NEVER commit this to git.
PRIVATE_KEY=
# Funder address (proxy wallet holders fund). Required if SIGNATURE_TYPE != 0.
FUNDER_ADDRESS=
# 0 = EOA, 1 = email/Magic, 2 = browser wallet proxy
SIGNATURE_TYPE=0
# Polygon RPC (only needed in live mode for balance/approval reads)
RPC_URL=https://polygon-rpc.com

# ── CLOB API ──────────────────────────────────────────────────────────
CHAIN_ID=137
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
# Optional — if blank, derived from wallet on first run
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# ── Event loop ────────────────────────────────────────────────────────
TICK_INTERVAL_MS=5000                # 5 seconds per trading iteration
MARKET_REFRESH_MS=15000              # Gamma API cache TTL
BOOK_REFRESH_MS=2000                 # CLOB orderbook cache TTL

# ── Market filters ────────────────────────────────────────────────────
MIN_VOLUME_24H=5000                  # USDC; skip illiquid markets
MAX_SPREAD=0.05                      # 5 cents; skip wide markets
MIN_DEPTH=200                        # USDC notional on each side
MIN_HOURS_TO_RESOLUTION=6            # skip markets resolving soon
ALLOWED_CATEGORIES=                  # comma-separated, empty = all

# ── Risk limits ───────────────────────────────────────────────────────
MAX_ORDER_QTY=200                    # contracts per single order
MAX_ORDER_NOTIONAL=100               # USDC per single order
MAX_POSITION_PER_MARKET=500          # contracts (YES+NO combined)
MAX_CONCURRENT_ORDERS=10
MAX_DAILY_LOSS=50                    # USDC; stops all trading for the day
MAX_DAILY_REJECTS=20                 # stops after N rejections in a day
MAX_SLIPPAGE_BPS=50                  # tolerated vs expected price

# ── Execution ─────────────────────────────────────────────────────────
DEFAULT_ORDER_TYPE=GTC                # GTC | FOK | FAK
LIMIT_OFFSET_TICKS=1                  # 1 = cross the spread by one tick
ORDER_TIMEOUT_MS=60000                # cancel resting orders older than this

# ── Retry ─────────────────────────────────────────────────────────────
RETRY_MAX=3
RETRY_BASE_MS=500
RETRY_MAX_MS=5000

# ── Paper-mode only ───────────────────────────────────────────────────
PAPER_USDC_BALANCE=1000               # starting balance for paper trading

# ── Logging ───────────────────────────────────────────────────────────
LOG_DIR=./logs
TRADE_LOG=trades.jsonl
ERROR_LOG=errors.jsonl
DECISION_LOG=decisions.jsonl
